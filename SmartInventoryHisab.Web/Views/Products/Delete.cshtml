@model SmartInventoryHisab.Model.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h1 class="card-title h3 mb-0">Delete Product?</h1>
                </div>
                <div class="card-body py-5">
                    <div class="mb-4 text-warning">
                        <i class="bi bi-exclamation-triangle-fill display-1"></i>
                    </div>
                    <p class="lead mb-2">Are you sure you want to delete <br><strong>@Model.Name</strong>?</p>
                    <p class="text-secondary small">This action will remove the product and its associated data permanently.</p>
                </div>
                <div class="card-footer d-flex justify-content-center gap-3 py-3">
                    <form asp-action="Delete" class="d-flex gap-3">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
