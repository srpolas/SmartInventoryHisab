@model SmartInventoryHisab.Model.Sale

@{
    ViewData["Title"] = "Record Sale";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 border rounded shadow p-4 bg-light border-success">
            <h2 class="text-center text-success mb-4">Record New Sale</h2>
            <hr />
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-4">
                    <label asp-for="ProductId" class="form-label fw-bold">Select Product to Sell</label>
                    <div class="input-group">
                        <span class="input-group-text bg-success text-white"><i class="bi bi-box-seam"></i></span>
                        <select asp-for="ProductId" class="form-select form-select-lg" asp-items="ViewBag.ProductId">
                            <option value="">-- Choose Product --</option>
                        </select>
                    </div>
                    <span asp-validation-for="ProductId" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Quantity" class="form-label fw-bold">Quantity to Sell</label>
                    <div class="input-group">
                        <span class="input-group-text bg-success text-white"><i class="bi bi-dash-lg"></i></span>
                        <input asp-for="Quantity" class="form-control form-control-lg" type="number" min="1" placeholder="Enter quantity" />
                    </div>
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-info-circle me-1"></i> Stock will be deducted immediately upon confirmation.
                    </small>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg shadow-sm">
                        Confirm Sale Record
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to Sales Records
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
