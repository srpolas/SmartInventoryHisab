@model SmartInventoryHisab.Model.Purchase

@{
    ViewData["Title"] = "Record Purchase";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 border rounded shadow p-4 bg-light">
            <h2 class="text-center text-primary mb-4">Record New Purchase</h2>
            <hr />
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-4">
                    <label asp-for="ProductId" class="form-label fw-bold">Select Product</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                        <select asp-for="ProductId" class="form-select form-select-lg" asp-items="ViewBag.ProductId">
                            <option value="">-- Choose a Product --</option>
                        </select>
                    </div>
                    <span asp-validation-for="ProductId" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Quantity" class="form-label fw-bold">Quantity to Add</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-plus-lg"></i></span>
                        <input asp-for="Quantity" class="form-control form-control-lg" type="number" min="1" placeholder="Enter amount" />
                    </div>
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                    <small class="text-muted">This will increase the current stock of the selected product.</small>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                        Confirm Purchase Record
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Back to History
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
